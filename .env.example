# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
DATABASE_PATH=./data/ai-company.db

# AI Model Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1

# Optional: Custom Model Providers
# CUSTOM_PROVIDER_API_KEY=your_custom_provider_api_key
# CUSTOM_PROVIDER_BASE_URL=https://your-custom-provider.com/v1

# Agent Configuration
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT_MS=300000

# Memory & Storage
MEMORY_PATH=./memory
LOGS_PATH=./logs

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=100

# Security
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here

# Feature Flags
ENABLE_TELEMETRY=true
ENABLE_AUTO_SAVE=true
ENABLE_HOT_RELOAD=true
