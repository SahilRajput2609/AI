        "shadow": "sm"
      },
      "states": {
        "online": { "accentBorder": "1px solid rgba(34,197,94,0.3)" },
        "running": { "accentBorder": "1px solid rgba(59,130,246,0.3)", "glow": "0 0 16px rgba(59,130,246,0.08)" },
        "idle": { "accentBorder": "1px solid rgba(148,163,184,0.2)" },
        "error": { "accentBorder": "1px solid rgba(239,68,68,0.3)" }
      }
    },
    "progressBar": {
      "height": 6,
      "borderRadius": 3,
      "background": "#1E293B",
      "fillTransition": "width 500ms cubic-bezier(0.4, 0, 0.2, 1)",
      "label": "small muted",
      "valueLabel": "small medium textPrimary"
    },
    "badge": {
      "variants": ["default", "success", "warning", "error", "info", "purple"],
      "common": {
        "display": "inline-flex",
        "alignItems": "center",
