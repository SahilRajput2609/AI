        "padding": "2px 8px",
        "borderRadius": 6,
        "fontSize": 11,
        "fontWeight": 500,
        "letterSpacing": "0.02em"
      },
      "colors": {
        "default": { "background": "rgba(148,163,184,0.12)", "color": "#94A3B8" },
        "success": { "background": "rgba(34,197,94,0.12)", "color": "#22C55E" },
        "warning": { "background": "rgba(245,158,11,0.12)", "color": "#F59E0B" },
        "error":   { "background": "rgba(239,68,68,0.12)",   "color": "#EF4444" },
        "info":    { "background": "rgba(59,130,246,0.12)",  "color": "#3B82F6" },
        "purple":  { "background": "rgba(139,92,246,0.12)",  "color": "#8B5CF6" }
      }
    },
    "kanbanCard": {
      "background": "#131A24",
      "borderRadius": 10,
