  "responsiveBreakpoints": {
    "2xl": { "minWidth": 1536, "layout": "full 3-column with expanded terminal" },
    "xl":  { "minWidth": 1280, "layout": "full 3-column" },
    "lg":  { "minWidth": 1024, "layout": "sidebar collapsed to 64px, activity panel slides over" },
    "md":  { "minWidth": 768,  "layout": "sidebar icons only, activity panel as overlay, terminal collapsible" },
    "sm":  { "minWidth": 640,  "layout": "single column, bottom navigation bar, all panels stacked" }
  },

  "animations": {
    "sidebarExpand": "width 300ms ease",
    "cardHover": "transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease",
    "modalEnter": "scale 200ms ease, opacity 200ms ease",
    "notificationEnter": "transform 300ms ease, opacity 300ms ease",
    "progressFill": "width 500ms cubic-bezier(0.4, 0, 0.2, 1)",
    "flowLines": "dash-offset 2s linear infinite",
    "pageTransition": "opacity 200ms ease, transform 200ms ease",
    "dragReorder": "transform 200ms ease"
  },

  "designedScreens": [
    "1. Main Workspace — full dashboard with sidebar navigation, agent flow canvas, chat activity panel, terminal, and floating notifications",
    "2. Task Board (Kanban) — four-column board (Backlog, In Progress, Review, Done) with drag-and-drop task cards, priority badges, and agent assignment",
    "3. File Explorer — collapsible folder tree, multi-tab code editor with One Dark Pro syntax theme, and optional side-by-side diff panel",
    "4. Activity Timeline — vertical chronological feed with agent actions, git events, and system logs, filterable and auto-scrolling",
    "5. Settings — categorized sidebar (General, Models, Agents, API Keys, Notifications, Shortcuts) with configuration cards (e.g. Model Configuration)",
    "6. Login / Onboarding — centered glassmorphism auth card with email/password form and GitHub/Google OAuth providers, animated gradient background",
    "7. Model Selector Overlay — anchored dropdown with search, grouped by Recommended/Fast, provider badges, and active model indicator"
  ]
}
