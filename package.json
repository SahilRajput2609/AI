{
  "name": "ai-company",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently -n dash,srv -c cyan,green \"npm run dev -w apps/dashboard\" \"npm run dev -w apps/server\"",
    "build": "npm run build -w apps/server && npm run build -w apps/dashboard",
    "start": "npm run start -w apps/server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p apps/dashboard/tsconfig.json && tsc --noEmit -p apps/server/tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx --ignore-pattern node_modules --ignore-pattern dist",
    "lint:fix": "eslint . --ext .ts,.tsx --fix --ignore-pattern node_modules --ignore-pattern dist",
    "format": "prettier --check \"**/*.{ts,tsx,json,css,md}\" --ignore-path .gitignore",
    "format:fix": "prettier --write \"**/*.{ts,tsx,json,css,md}\" --ignore-path .gitignore",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.3",
    "concurrently": "^10.0.3",
    "eslint": "^9.24.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.22.0",
    "react-redux": "^9.3.0",
    "ws": "^8.21.0"
  }
}
